msgid "Software Update"
msgstr "Cập nhật phần mềm"

msgid "Update available"
msgstr "Có bản cập nhật mới"

msgid "Update tonight"
msgstr "Cập nhật vào tối nay"

msgid "Update now"
msgstr "Cập nhật ngay"

msgid "Check for updates"
msgstr "Kiểm tra bản cập nhật mới"

msgid "Your system is up to date."
msgstr "Hệ thống đang ở bản mới nhất."

msgid "Automatic updates"
msgstr "Tự động cập nhật"

msgid "Previous version"
msgstr "Phiên bản trước"

msgid "Roll back"
msgstr "Hoàn tác"

msgid "Roll back and restart"
msgstr "Hoàn tác và khởi động lại"

msgid "Restart now"
msgstr "Khởi động lại ngay"

msgid "Restart later"
msgstr "Khởi động lại sau"

msgid "Cancel"
msgstr "Huỷ"

msgid "Update ready"
msgstr "Bản cập nhật đang chuẩn bị"

msgid "Downloading update…"
msgstr "Bản cập nhật đang tải về…"

msgid "Roll back to previous version?"
msgstr "Hoàn tác về phiên bản trước?"

msgid "Updates are applied atomically and can always be rolled back. Your files and settings are never affected."
msgstr ""
"Bản cập nhật được cài đặt một cách chính xác hoàn toàn và luôn có thể hoàn "
"tác. Dữ liệu và cài đặt của bạn không bao giờ bị ảnh hưởng."

msgid "An error occurred"
msgstr "Lỗi đã xảy ra"

msgid "Transaction log"
msgstr "Nhật ký thao tác"

msgid "Update scheduled"
msgstr "Bản cập nhật đã được lên lịch"

msgid "Rollback ready"
msgstr "Thao tác hoàn tác đang chuẩn bị"

msgid "Checking…"
msgstr "Đang kiểm tra…"

msgid "System updates are paused"
msgstr "Các bản cập nhật hệ thống đang tạm dừng"

msgid "Packages layered with rpm-ostree prevent updates: %1"
msgstr "Các gói phần mềm được chồng với rpm-ostree đang chặn việc cập nhật: %1"

msgid "Remove packages…"
msgstr "Gỡ cài đặt gói phần mềm…"

msgid "Remove layered packages?"
msgstr "Gỡ cài đặt các ứng dụng đang chồng lên?"

msgid ""
"The following packages will be removed and the system will restart "
"afterwards:\n"
"\n"
"%1"
msgstr ""
"Các gói phần mềm sau sẽ được gỡ cài đặt và hệ thống sẽ khởi động lại sau "
"đó:\n"
"\n"
"%1"

msgid "Remove packages and restart"
msgstr "Gỡ cài đặt gói phần mềm và khởi động lại"

msgid "Layered packages are being removed"
msgstr "Các gói phần mềm được chồng lên đang được gỡ bỏ"

msgid "Try again"
msgstr "Thử lại"

msgid "The update could not be completed."
msgstr "Phiên cập nhật không thể hoản thành."

msgid "Updating %1"
msgstr "Đang cập nhật %1"

msgid "Rolling back %1"
msgstr "Đang hoàn tác %1"

msgid "Unknown error"
msgstr "Lỗi không rõ nguyên nhân"

msgid "Failed to connect to rpm-ostree transaction"
msgstr "Kết nối với phiên rpm-ostree thất bại"

msgid "Removing layered packages"
msgstr "Đang gỡ bỏ gói phần mềm được chồng lên"
